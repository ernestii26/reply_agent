# =============================================
# web_agent 環境變數設定範本
# 複製此檔案為 .env 並填入實際資訊
# =============================================

# ---- 論壇登入（User 1）----
EMAIL=your_email@example.com
PASSWORD=your_password

# ---- 論壇登入（User 2）----
EMAIL2=your_email2@example.com
PASSWORD2=your_password2
USER_NAME2=柚子｜逢甲RMIT商學系學長  # 論壇上的顯示名稱，用於檢查是否已回覆

# ---- Google Gemini API ----
# 單一 Key（基本用法）
GEMINI_API_KEY=your_gemini_api_key_here

# 多 Key 輪替（選填）：任一 Key 失敗時立即切換，不等待
# 支援 JSON 陣列或逗號分隔格式，設定後 GEMINI_API_KEY 仍可保留作降級
# JSON 陣列格式：
# GEMINI_API_KEYS=["AIzaSy...", "AIzaSy...", "AIzaSy..."]
# 逗號分隔格式：
# GEMINI_API_KEYS=AIzaSy...,AIzaSy...,AIzaSy...

# 免費申請：https://aistudio.google.com/app/apikey
# 免費額度：每天 1500 次請求（gemini-2.5-flash）

# ---- Serper.dev 外部搜尋（選填）----
# 未設定時，自動停用 RAG 知識增強，AI 仍可正常回覆
SERPER_API_KEY=your_serper_api_key_here
# 免費申請：https://serper.dev/

# ---- Google Drive 同步 ----
GDRIVE_CLIENT_ID=
GDRIVE_CLIENT_SECRET=
GDRIVE_REFRESH_TOKEN=
GDRIVE_DB_FOLDER_ID=
GDRIVE_SCREENSHOTS_FOLDER_ID=   # User 1 截圖資料夾
GDRIVE_SCREENSHOTS_FOLDER_ID2=  # User 2 截圖資料夾
