# 網站登入資訊
EMAIL=your_email@example.com
PASSWORD=your_password

# Google Gemini API Key (免費註冊: https://makersuite.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# 使用說明：
# 1. 複製此檔案並重新命名為 .env
# 2. 填入你的實際資訊
# 3. Gemini API Key 可以在 https://makersuite.google.com/app/apikey 免費申請
# 4. 每天有1500次免費請求額度
